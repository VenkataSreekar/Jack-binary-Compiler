function MAC.RowXCol 4
    push constant 0
    pop local 0

    push constant 0
    pop local 1
    
    push argument 0
    pop local 2
    
    push argument 1
    pop local 3

label LOOP_START
    push local 1
    push argument 2
    eq
    if-goto LOOP_END

    push local 2
    pop pointer 1
    push that 0

    push local 3
    pop pointer 1
    push that 0

    call Math.multiply 2
    push local 0
    add
    pop local 0

    push local 2
    push constant 1
    add
    pop local 2

    push local 3
    push argument 3
    add
    pop local 3

    push local 1
    push constant 1
    add
    pop local 1
    goto LOOP_START

label LOOP_END
    push local 0
    return